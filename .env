# ─────────────────────────────────────────────────────────────
# DATABASE
# Use a hosted Postgres instance (Neon, Supabase, Railway...).
# Netlify Functions are stateless/serverless, so SQLite will NOT work
# in production — you need a real network-accessible database.
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:npg_cQeGKqh7fuU9@ep-wild-lake-atk452bt-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─────────────────────────────────────────────────────────────
# ADMIN
# Only an account registered with this exact Roblox username can ever
# become admin (case-insensitive). This is self-reported at signup, NOT
# verified via any Roblox login — so registering with this Roblox username
# ALSO requires the secret below, to stop anyone else from typing it in
# and claiming admin.
# ─────────────────────────────────────────────────────────────
ADMIN_ROBLOX_USERNAME="Madhuri153"

# Generate with: openssl rand -hex 24
# Give this value directly to the one person who should be admin — never
# put it in the UI, a public channel, or commit it anywhere.
ADMIN_CLAIM_SECRET="ProplayerGalaxyMagGamerpro1667chaosflo44FanFromTheDAn!#431321"

# ─────────────────────────────────────────────────────────────
# DISCORD WEBHOOK (fallback / initial value — can also be changed
# live from the admin panel, which stores it encrypted in the database)
# ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/1524887124569100328/cbWA14G5v1fCjkroz5_8iiRxsBmAQXDlTD2KCVt5b0Rq351YrpfXmmDTRW7epE-ZFMFS"

# Secret used to symmetrically encrypt the webhook URL & other
# sensitive settings at rest in the database.
# Generate with: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY="3f8b9d4a2c1e7f605129b4c7d8a3e1f0c2b5e9d3f4a8c1b6e7d2a9f0c5b4e3d1"

# ─────────────────────────────────────────────────────────────
# RATE LIMITING (Upstash Redis — free tier is enough to start)
# https://upstash.com — create a Redis database, copy REST credentials.
# If left empty, an in-memory limiter is used as a fallback (fine for
# local dev, NOT sufficient across multiple serverless instances).
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────────────────────
# BOT PROTECTION (Cloudflare Turnstile — free)
# https://dash.cloudflare.com/?to=/:account/turnstile
# Once set, the "I'm not a robot" widget automatically appears on the
# login, register, and code-redemption forms — no code changes needed.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAADylrDAGM90df6CW"
TURNSTILE_SECRET_KEY="0x4AAAAAADy1rMP77_QrgsLsTKReLe_tmHA"
